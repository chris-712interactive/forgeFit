# forgeFit environment variables
# Copy to apps/web/.env.local

# Supabase (required for Phase 1 auth + onboarding)
# 1. Create project at https://supabase.com
# 2. Run migration: supabase db push (or paste SQL from supabase/migrations/)
# 3. Enable Email auth + Google OAuth in Authentication > Providers
# 4. Add redirect URL: http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Phase 7 — Pro tier)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Device integrations (Phase 7)
# WITHINGS_CLIENT_ID=
# WITHINGS_CLIENT_SECRET=
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=

# AI coaching copy (Phase 8 — optional)
# OPENAI_API_KEY=
