# forgeFit environment variables
# Copy to apps/web/.env.local

# Supabase (required for Phase 1 auth + onboarding)
# 1. Create project at https://supabase.com
# 2. Run migration: supabase db push (or paste SQL from supabase/migrations/)
# 3. Enable Email auth + Google OAuth in Authentication > Providers
# 4. Supabase Auth → URL Configuration:
#    Site URL: your production origin (e.g. https://www.joinforgefit.com)
#    Redirect URLs (add every origin you use; use ** so ?next= survives):
#      http://localhost:3000/auth/callback**
#      https://joinforgefit.com/auth/callback**
#      https://www.joinforgefit.com/auth/callback**
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for account deletion (server-side only — never expose to the client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Tag Manager (required for MNTN and other marketing pixels)
# Create a Web container at https://tagmanager.google.com — ID format: GTM-XXXXXXX
# When set, direct GA4 script is disabled; add a GA4 Configuration tag in GTM instead.
# NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-57PG354W

# Google Analytics (fallback when GTM is not configured)
# Optional in local dev; enabled by default in production without GTM.
# Set to "false" to disable. Override ID if you rotate the property.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-VDVFTLJ0NF

# Canonical production origin (required on Vercel for OAuth redirect URIs, sitemap, metadata)
# Must match the domain users visit and what you register with Spotify / Google / Strava.
# NEXT_PUBLIC_SITE_URL=https://forge-rep.com

# ForgeRep Admin Console — comma-separated Supabase user UUIDs with /admin access
# Also set profiles.is_admin = true in DB for persistent admin flag.
# Sign in at /admin/login (not /login).
# ADMIN_USER_IDS=your-user-uuid-here

# Signs the forge_impersonate cookie for read-only "view as user" from admin console.
# Falls back to CRON_SECRET if unset. Generate: openssl rand -base64 32
# ADMIN_IMPERSONATION_SECRET=

# Stripe (Phase 7 — Pro + Pro+ tiers)
# Create Products in Stripe Dashboard (see docs/TIER-GATES.md):
#   ForgeRep Pro     — $8.99/month,  $69.99/year
#   ForgeRep Pro+    — $14.99/month, $119.99/year
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRO_PRICE_ID_MONTHLY=price_...
# STRIPE_PRO_PRICE_ID_ANNUAL=price_...
# STRIPE_PRO_PLUS_PRICE_ID_MONTHLY=price_...
# STRIPE_PRO_PLUS_PRICE_ID_ANNUAL=price_...
# Enable Stripe Customer Portal (Dashboard → Settings → Billing → Customer portal)
# and add all Pro / Pro+ prices so users can switch plans there too.
# Legacy (maps to Pro if STRIPE_PRO_* unset):
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_ANNUAL=price_...

# Device integrations (Phase 7 — Pro+)
# Generate encryption key: openssl rand -base64 32
# INTEGRATIONS_TOKEN_ENCRYPTION_KEY=
# WITHINGS_CLIENT_ID=
# WITHINGS_CLIENT_SECRET=
# Register redirect URI: https://your-domain/api/integrations/withings/callback
# Setup + QA: docs/integrations/withings-setup.md
# Fitbit activity sync uses the Google Health API (not legacy fitbit.com OAuth).
# Add this EXACT URI to your Web OAuth client's authorized redirect URIs:
#   {NEXT_PUBLIC_SITE_URL}/api/integrations/fitbit/callback
# Example: https://joinforgefit.com/api/integrations/fitbit/callback
# GOOGLE_HEALTH_CLIENT_ID=
# GOOGLE_HEALTH_CLIENT_SECRET=
# Legacy aliases (optional): FITBIT_CLIENT_ID= / FITBIT_CLIENT_SECRET=
# Strava — create an app at https://www.strava.com/settings/api
# Authorized redirect URI: {NEXT_PUBLIC_SITE_URL}/api/integrations/strava/callback
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=

# Production: set NEXT_PUBLIC_SITE_URL on Vercel and register:
#   https://forge-rep.com/api/integrations/spotify/callback
# Local dev example: http://localhost:3000/api/integrations/spotify/callback
# SPOTIFY_OAUTH_REDIRECT_URI=
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Vercel Cron — daily Fitbit sync (generate: openssl rand -base64 32)
# Set the same value in Vercel project env; Vercel sends Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=

# Community web push (Phase 4 — requires SUPABASE_SERVICE_ROLE_KEY for sending)
# Generate VAPID keys: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# Community weekly recap email (Resend — https://resend.com)
# RESEND_API_KEY=re_...
# EMAIL_FROM=ForgeFit <recaps@yourdomain.com>

# Ingredient suggestion alerts (uses Resend + EMAIL_FROM above)
# NUTRITION_INGREDIENT_FEEDBACK_TO=you@example.com

# Review pending ingredient suggestions (requires CRON_SECRET + SUPABASE_SERVICE_ROLE_KEY):
# curl -H "Authorization: Bearer $CRON_SECRET" \
#   "https://your-app.vercel.app/api/internal/nutrition-ingredient-suggestions"

# USDA FoodData Central (Phase 4 — optional, improves branded US food search)
# Free key: https://fdc.nal.usda.gov/api-key-signup.html
# USDA_FDC_API_KEY=

# AI coaching copy (Phase 8 — optional)
# OPENAI_API_KEY=
