# forgeFit environment variables
# Copy to apps/web/.env.local

# Supabase (required for Phase 1 auth + onboarding)
# 1. Create project at https://supabase.com
# 2. Run migration: supabase db push (or paste SQL from supabase/migrations/)
# 3. Enable Email auth + Google OAuth in Authentication > Providers
# 4. Supabase Auth → URL Configuration:
#    Site URL: your production origin (e.g. https://www.joinforgefit.com)
#    Redirect URLs (add every origin you use):
#      http://localhost:3000/auth/callback
#      https://joinforgefit.com/auth/callback
#      https://www.joinforgefit.com/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for account deletion (server-side only — never expose to the client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Phase 7 — Pro + Pro+ tiers)
# Create Products in Stripe Dashboard (see docs/TIER-GATES.md):
#   ForgeFit Pro     — $8.99/month,  $69.99/year
#   ForgeFit Pro+    — $14.99/month, $119.99/year
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRO_PRICE_ID_MONTHLY=price_...
# STRIPE_PRO_PRICE_ID_ANNUAL=price_...
# STRIPE_PRO_PLUS_PRICE_ID_MONTHLY=price_...
# STRIPE_PRO_PLUS_PRICE_ID_ANNUAL=price_...
# Legacy (maps to Pro if STRIPE_PRO_* unset):
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_ANNUAL=price_...

# Device integrations (Phase 7)
# WITHINGS_CLIENT_ID=
# WITHINGS_CLIENT_SECRET=
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=

# USDA FoodData Central (Phase 4 — optional, improves branded US food search)
# Free key: https://fdc.nal.usda.gov/api-key-signup.html
# USDA_FDC_API_KEY=

# AI coaching copy (Phase 8 — optional)
# OPENAI_API_KEY=
